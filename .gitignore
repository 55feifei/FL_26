# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# 虚拟环境
.venv/
venv/
env/
ENV/

# ===== 数据集（体积大，从 PC scp 拷贝，不入库） =====
data/
!data/.gitkeep

# ===== 训练产物（全部为运行生成，含 noniid_research/ 等子目录，不入库）=====
# 用 results/* 而非 results/，否则无法用 !保留 .gitkeep（git 不能反选被忽略目录内的文件）
results/*
!results/.gitkeep

# ===== 日志/临时文件 =====
*.log
*.tmp
*.bak
*.swp
*~
*.zip
scripts/_tmp_*

# ===== IDE / 编辑器 =====
.vscode/
.idea/
*.iml

# ===== 操作系统 =====
.DS_Store
Thumbs.db
desktop.ini

# ===== Jupyter =====
.ipynb_checkpoints/
